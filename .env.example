# API Keys Configuration for The Super App
# Copy or edit this file to supply your actual API credentials.
# If these keys are left empty, the application will automatically fall back
# to the high-fidelity mock data and your manually added widescreen assets.

# OpenWeatherMap API Key
# Sign up at: https://openweathermap.org/api
VITE_WEATHER_API_KEY=

# NewsAPI API Key
# Sign up at: https://newsapi.org/
VITE_NEWS_API_KEY=

# OMDB API Key
# Sign up at: https://www.omdbapi.com/
VITE_OMDB_API_KEY=
